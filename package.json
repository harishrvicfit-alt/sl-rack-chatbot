{
  "name": "sl-rack-chatbot",
  "version": "1.0.0",
  "description": "AI sales and product assistant for SL Rack customers.",
  "type": "module",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "ingest:downloads": "node scripts/ingestDownloads.js",
    "check": "node --check server.js && node --check public/app.js && node --check public/admin.js && node --check src/analyticsDatabase.js && node --check src/rateLimit.js",
