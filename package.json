    "test:links": "node scripts/checkKnowledgeLinks.js",
    "admin:hash": "node scripts/hashAdminPassword.js"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/blob": "^2.6.1",
    "@vercel/functions": "^3.7.5",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "openai": "^4.77.0"
  }
}
